@startuml
skinparam classAttributeIconSize 0
skinparam linetype ortho

' ==========================================
' 1. ENUMS
' ==========================================
enum NavMode {
  IDLE
  TRACKING
  OFF_ROUTE
  ARRIVED
}

enum SyncStatus {
  LOCAL
  SYNCING
  CLOUD
  ERROR
}

enum DownloadStatus {
  IDLE
  DOWNLOADING
  SUCCESS
  FAILED
}

enum HomeScreenTab {
  MENU
  PROFIL
  PLANER
  ARCHIV
  DOWNLOAD
}

' ==========================================
' 2. MODELS & REAKTIVE STATES
' ==========================================
class UserProfile {
  + String id
  + String name
  + String email
}

class Tour {
  + id: String
  + title: String
  + userWaypoints: List<LatLng>
  + routePoints: List<LatLng>
  + distance: double
  + syncStatus: SyncStatus
}
class NavigationState {
  + NavMode mode
  + LatLng? currentPos
  + String? directionHint
  + bool isActive
}

' ==========================================
' 3. UI LAYER (Widgets & States)
' ==========================================
package "Presentation Layer" {

  class HomeScreen extends StatefullWidget{
    + createState(): _HomeScreenState
  }
  
  class _HomeScreenState {
    - _activeTab: HomeScreenTab
    
    + build(context: BuildContext): Widget
    + changeTab(tab: HomeScreenTab): void
  }

  class ProfilScreen extends StatefullWidget {
    + createState(): _ProfilScreenState
  }
  class _ProfilScreenState {
    -_userProfil: UserProfil
    -_loadProfil(): void
    + initState(): void
    + build(context: BuildContext): Widget
  }

  class TourPlanerScreen extends StatefullWidget {
    + initialTour: Tour?
    + createState(): _TourPlanerScreenState
  }
  class _TourPlanerScreenState {
    - _waypoints: List<LatLng>
    - isSaving: bool
    + initState(): void
    + build(context: BuildContext): Widget
  }

  class TourScreen extends StatefullWidget {
    + initState(): void
    + build(context: BuildContext): Widget
    + createState(): _ArchivScreenState
  }
  class _TourScreenState {
    - _currentFilter: TourFilter?
    - _plannedTours: List<Tour>?
    - _doneTours: List<Tour>?
    - _plannedCount: int = 0
    - _doneCount: int = 0
    - _loadCounts(): void
    - _loadTourList(filter: TourFilter): void
    + initState(): void
    + build(context: BuildContext): Widget
  }

  class NavigationScreen extends StatefullWidget {
    + initialTour: Tour?
    + createState(): _NavigationScreenState
  }
  class _NavigationScreenState {
    - double currentProgress
    - DownloadStatus status
  }
}

' ==========================================
' 4. LOGIC & DATA LAYER
' ==========================================
class NavigationProvider <<ChangeNotifier>> {
  - NavigationState _state
  - Tour? _activeTour
  + void start(Tour t)
}

class AppRepository {
  - LocalDatabase _db
  - RemoteApi _api
  - UserProfile? _currentUser
  + Future<UserProfile> loadProfile()
  + Future<void> saveTour(Tour t)
}

class GPSService {
  + Stream<LatLng> get positionStream
}

' ==========================================
' 5. ASSOZIATIONEN & KARDINALITÄTEN
' ==========================================

' Dashboard Steuerung über Enum statt Widget-Objekt
HomeScreen "1" *-- "1" _HomeScreenState
_HomeScreenState "1" o-- "1" HomeScreenTab : steuert über >

' Das Dashboard "kennt" die Ziel-Widgets (Dependency)
_HomeScreenState "1" *-- "1" ProfilScreen
_HomeScreenState "1" *-- "1" TourPlanerScreen
_HomeScreenState "1" *-- "1" TourScreen
_HomeScreenState "1" *-- "1" NavigationScreen

' Widget-State Verknüpfungen
ProfilScreen "1" *-- "1" _ProfilScreenState
TourPlanerScreen "1" *-- "1" _TourPlanerScreenState
TourScreen "1" *-- "1" _TourScreenState
NavigationScreen "1" *-- "1" _NavigationScreenState

' UserProfile ist fest im Repository verankert
AppRepository "1" *-- "0..1" UserProfile : verwaltet >
_ProfilScreenState "1" --> "1" AppRepository : nutzt >
_TourScreenState "1" --> "1" AppRepository : nutzt >
_TourPlanerScreenState "1" --> "1" AppRepository : nutzt >

' Navigation & Hardware
NavigationProvider "1" *-- "1" NavigationState : hält >
NavigationProvider "1" o-- "1" GPSService : nutzt >
NavigationProvider "1" *-- "0..1" Tour : aktiv >

' Enums als Datentypen
Tour "1" o-- "1" SyncStatus
NavigationState "1" o-- "1" NavMode
_DownloadScreenState "1" o-- "1" DownloadStatus

' Daten-Infrastruktur
AppRepository "1" *-- "1" LocalDatabase : persistiert >
AppRepository "1" o-- "1" RemoteApi : synchronisiert >
AppRepository "1" --> "0..*" Tour : verwaltet >

@enduml
