@startuml
skinparam actorStyle awesome
left to right direction

actor "Wanderer" as user
actor "GPS Sensor" as gps << System >>
actor "Map Service / API" as api << System >>

rectangle "Wander App (MVP)" {
    usecase "Karte explorieren" as UC1
    usecase "Route erstellen" as UC2
    usecase "Wegpunkte hinzufügen" as UC2a
    usecase "Navigation starten" as UC3
    usecase "Tour speichern & verwalten" as UC4
    usecase "Points of Interest (POI) anzeigen" as UC5
    usecase "Aktuelle Position tracken" as UC6
}

' Beziehungen des Wanderers
user --> UC1
user --> UC2
user --> UC3
user --> UC4
user --> UC5

' Erweiterung der Routen-Erstellung durch Wegpunkte
UC2 <.. UC2a : <<extend>>
note right of UC2a : User kann Zwischenstopps \nfestlegen

' System-Interaktionen
UC1 <-- api : "Kartenmaterial laden"
UC2 <-- api : "Berechnet Pfad via Waypoints"
UC3 <-- gps : "Liefert Echtzeit-Koordinaten"
UC6 -- gps : "Sensor Daten"
UC5 <-- api : "POI Daten laden"

' Verbindung zwischen Navigation und Tracking
UC3 ..> UC6 : <<include>>
@enduml
