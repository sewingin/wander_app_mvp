@startuml
' =========================
' CONTROLLER
' =========================
class AppController {
  +initApp()
  +setActiveComponent(name)
  +handleBack()
  +startNavigation(route)
  +stopNavigation()
  -activeComponent
}

' =========================
' MAIN VIEW
' =========================
class MainView {
  +render()
  +showComponent(name)
}

' =========================
' COMPONENTS
' =========================

class HomeComponent {
  +showMenu()
  +onSelectMap()
  +onSelectTours()
  +onSelectProfile()
  +onSelectSettings()
}

class MapComponent {
  +showMap()
  +showRoute(route)
  +showPOIs(pois)
  +updatePosition(coord)
  +onMapClick()
  +onCreateRoute()
  +hasUnsavedChanges(): boolean
}

class TourListComponent {
  +showTours(tours)
  +selectTour(tourId)
}

class ProfileComponent {
  +showUserProfile(user)
  +editProfile()
}

class SettingsComponent {
  +showSettings()
  +updateSettings()
}

class NavigationComponent {
  +startNavigation(route)
  +updateNavigation(state)
  +stopNavigation()
}

' =========================
' SERVICES
' =========================

class RoutingService {
  +calculateRoute(start, end)
  +loadRoute(routeId)
}

class POIService {
  +getPOIs(area)
}

class TourService {
  +getTours()
  +getTourById(id)
}

class NavigationService {
  +start(route)
  +stop()
  +updatePosition(coord)
  +getState(): NavigationState
}

class TileService {
  +loadTiles(x, y, z)
}

' =========================
' STATE
' =========================

class NavigationState {
  +isActive: boolean
  +currentRoute
  +currentPosition
  +remainingDistance
}

' =========================
' RELATIONSHIPS
' =========================

' Controller steuert MainView
AppController "1" --> "1" MainView : updates UI

' MainView enthält Komponenten (nur eine aktiv)
MainView "1" --> "0..1" HomeComponent : displays
MainView "1" --> "0..1" MapComponent : displays
MainView "1" --> "0..1" TourListComponent : displays
MainView "1" --> "0..1" ProfileComponent : displays
MainView "1" --> "0..1" SettingsComponent : displays
MainView "1" --> "0..1" NavigationComponent : displays

' Controller nutzt Services
AppController "1" --> "1" RoutingService : calculates routes
AppController "1" --> "1" TourService : manages tours
AppController "1" --> "1" NavigationService : controls navigation

' Komponenten nutzen Services
MapComponent "1" --> "1" POIService : loads POIs
MapComponent "1" --> "1" RoutingService : requests routes
MapComponent "1" --> "1" TileService : renders map tiles

TourListComponent "1" --> "1" TourService : loads tours

' Navigation
NavigationService "1" --> "1" NavigationState : manages state
NavigationComponent "1" --> "1" NavigationState : displays state
@enduml
